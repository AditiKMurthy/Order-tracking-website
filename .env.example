# ============================================================
# Environment Variables for Order Track Application
# ============================================================
# IMPORTANT: This file contains placeholder values for all
# environment variables. Copy this to .env and fill in actual
# values for your deployment. NEVER commit .env to version control.
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# PostgreSQL database URL in the format:
# postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/order_db

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================
# JWT Secret Key - Generate a strong, random secret key
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Token expiration time in hours
JWT_EXPIRATION_HOURS=2

# Algorithm used for JWT encoding/decoding
JWT_ALGORITHM=HS256

# ============================================================
# FASTAPI SERVER CONFIGURATION
# ============================================================
# Backend server URL accessible from frontend
FASTAPI_URL=http://localhost:8000

# ============================================================
# REDIS CONFIGURATION (Caching & Session Layer)
# ============================================================
# Redis server hostname
REDIS_HOST=localhost

# Redis server port
REDIS_PORT=6379

# Redis database number (optional)
REDIS_DB=0

# Redis password (if required)
REDIS_PASSWORD=

# ============================================================
# KAFKA CONFIGURATION (Event Streaming & Pipeline)
# ============================================================
# Kafka broker addresses (comma-separated for multiple brokers)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka topic for order events
KAFKA_ORDER_TOPIC=orders

# Kafka consumer group ID
KAFKA_CONSUMER_GROUP=order_consumers

# ============================================================
# QDRANT CONFIGURATION (Vector Store & AI/ML)
# ============================================================
# Qdrant vector database hostname
QDRANT_HOST=localhost

# Qdrant vector database port
QDRANT_PORT=6333

# Qdrant API key (if authentication is enabled)
QDRANT_API_KEY=

# Qdrant collection name for storing company policies
QDRANT_COLLECTION_NAME=company_policies

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (only set to true in development)
DEBUG=false

# Application log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Support/Help email for documentation and customer contact
SUPPORT_EMAIL=support@omnistream.com

# ============================================================
# DOCKER COMPOSE SERVICES (for docker-compose.yml)
# ============================================================
# PostgreSQL container environment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=order_db

# Zookeeper configuration
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# Kafka configuration
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092,PLAINTEXT_INTERNAL://kafka:29092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_INTERNAL:PLAINTEXT
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# ============================================================
# OPTIONAL: PRODUCTION SECRETS (if using external services)
# ============================================================
# API Keys for third-party services (uncomment and fill if needed)
# OPENAI_API_KEY=your_openai_api_key
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# EXTERNAL_API_TOKEN=your_external_api_token
